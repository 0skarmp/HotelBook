@{
    ViewData["Title"] = "Perfil";
    ViewData["ShowSidebar"] = true;
    Layout = "_Layout";
}

@await Html.PartialAsync("_Header")

<main class="p-6 text-black">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-indigo-700">Perfil de Usuario</h1>
        <p class="text-gray-600">Aquí puedes ver los datos de tu usuario y cerrar turno.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Información del usuario</h2>
            <div class="space-y-3 text-sm text-gray-700">
                <div>
                    <span class="font-semibold">Nombre:</span>
                    <span id="profileUsername">Invitado</span>
                </div>
                <div>
                    <span class="font-semibold">Correo:</span>
                    <span id="profileEmail">No disponible</span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Acciones</h2>
            <button id="profileLogoutBtn" class="w-full px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">Cerrar turno</button>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const user = JSON.parse(localStorage.getItem('hotelCurrentUser') || 'null');
        const usernameEl = document.getElementById('profileUsername');
        const emailEl = document.getElementById('profileEmail');
        const logoutBtn = document.getElementById('profileLogoutBtn');

        if (user && user.username) {
            usernameEl.textContent = user.username;
            emailEl.textContent = user.email || 'Sin correo';
        }

        logoutBtn.addEventListener('click', () => {
            localStorage.removeItem('hotelCurrentUser');
            window.location.href = '/Login';
        });
    });
</script>
