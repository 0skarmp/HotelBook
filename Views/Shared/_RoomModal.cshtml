{
@Layout = "_Layout";
}

@model Hotel.Models.Room

<div id="roomModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center">
    <div class="bg-white p-6 rounded shadow-lg w-96">
        <h2 class="text-xl font-bold mb-4">Nueva Habitación</h2>
        <form id="roomForm">
            <div class="mb-2">
                <label class="block">Número</label>
                <input type="text" id="roomNumber" class="w-full border rounded p-2" />
            </div>
            <div class="mb-2">
                <label class="block">Tipo</label>
                <select id="roomType" class="w-full border rounded p-2">
                    <option value="Simple">SWD</option>
                    <option value="Doble">DWB</option>
                    <option value="Suite">Suite</option>
                    <option value="SuiteJr">Suite Jr</option>
                </select>
            </div>
            <div class="mb-2">
                <label class="block">Status</label>
                <select id="roomStatus" class="w-full border rounded p-2">
                    <option value="Libre">Libre</option>
                    <option value="Ocupada">Ocupada</option>
                    <option value="Reservada">Reservada</option>
                    <option value="Limpieza">Limpieza</option>
                    <option value="Vencido">Vencido</option>
                </select>
            </div>
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" id="closeModalBtn" class="px-4 py-2 bg-gray-400 text-white rounded">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded">Crear</button>
            </div>
        </form>
    </div>
</div>
