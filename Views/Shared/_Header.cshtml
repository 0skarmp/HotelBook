@{
    Layout = "_Layout";
}
<div class="bg-gray-50 border-b px-6 py-3 flex items-center justify-between">

    <!-- IZQUIERDA -->
    <div class="flex items-center gap-3">
        <span class="text-gray-400 cursor-pointer text-lg">✕</span>

        <div>
            <h2 class="text-sm font-semibold text-gray-800">
                Bienvenido, .Usuario
            </h2>
            <p class="text-xs text-gray-500">
                @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy")
            </p>
        </div>
    </div>

    <!-- DERECHA -->
    <div class="flex items-center gap-3">

        <!-- HOTEL -->
        <div class="bg-blue-100 text-blue-700 text-xs px-3 py-1 rounded-full flex items-center gap-1">
            🏨 Hotel Imperial
        </div>

        <!-- CAJA -->
        <div class="bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full flex items-center gap-2">
            🔒 Cerrar Caja
            <span class="bg-green-200 px-2 py-0.5 rounded-full font-semibold">
                $20.00
            </span>
        </div>

        <!-- PRO -->
        <div class="bg-yellow-100 text-yellow-700 text-xs px-3 py-1 rounded-full flex items-center gap-1">
            👑 Pro
        </div>

        <!-- USUARIO -->
        <div class="flex items-center gap-2 ml-2">
            <div class="w-8 h-8 bg-blue-500 text-white rounded-full flex items-center justify-center font-bold">
                .Usuario.Substring(0, 1)
            </div>

            <div class="text-xs text-gray-700">
                <div class="font-semibold">Usuario</div>
                <div class="text-gray-500">Ver perfil</div>
            </div>
        </div>

    </div>
</div>