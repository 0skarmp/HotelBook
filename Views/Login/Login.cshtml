@{
    Layout = "_MinimalLayout";
    ViewData["Title"] = "Login";
}

<div class="min-h-screen bg-cover bg-center flex items-center justify-center"
     style="background-image: url('/img/hotel.jpg')">
    <div class="bg-slate-700 bg-opacity-80 p-8 rounded shadow-md w-96">
        <h2 class="text-2xl font-bold mb-4 text-center text-white">BIENVENIDOS A HOTEL CONTROLLER</h2>
        <img src="/img/hotelvirtual.png" alt="Hotel Logo" class="mx-auto mb-6 w-40 h-32">
        <form id="loginForm" method="post" action="/api/login/login">
            <input type="text" id="username" name="username" placeholder="Ingresa tu usuario"
                   class="w-full mb-3 p-2 border rounded focus:border-blue-500">
            <input type="password" id="password" name="password" placeholder="Ingresa tu contraseña"
                   class="w-full mb-3 p-2 border rounded focus:border-blue-500">
            
            <div class="flex items-center mb-3">
                <input type="checkbox" id="showPassword" class="mr-2">
                <label for="showPassword" class="text-sm text-white">Mostrar contraseña</label>
            </div>
            
            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
                Ingresar
            </button>
        </form>
        
        <div id="error" class="text-red-600 text-sm mt-2"></div>
    </div>
</div>

<script>
    document.getElementById("loginForm").addEventListener("submit", async (e) => {
        e.preventDefault();

        const response = await fetch("/api/login/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                Username: document.getElementById("username").value,
                Password: document.getElementById("password").value
            })
        });

        if (response.ok) {
            const data = await response.json();
            localStorage.setItem('hotelCurrentUser', JSON.stringify({
                username: data.username || document.getElementById('username').value,
                email: data.email || ''
            }));
            window.location.href = "/Dashboard";
        } else {
            const errorData = await response.json().catch(() => null);
            document.getElementById("error").innerText = errorData?.error || "Usuario o contraseña incorrectos";
        }
    });

    const checkbox = document.getElementById("showPassword");
    const passwordInput = document.getElementById("password");
    checkbox.addEventListener("change", () => {
        passwordInput.type = checkbox.checked ? "text" : "password";
    });
</script>
