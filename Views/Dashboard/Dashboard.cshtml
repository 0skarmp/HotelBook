@{
    ViewData["Title"] = "Dashboard";
    ViewData["ShowSidebar"] = true;
    Layout = "_Layout";
}

@await Html.PartialAsync("_Header")

<main class="p-6 text-black">
    <h1 class="text-2xl font-bold mb-4 text-indigo-700">Calendario de Habitaciones</h1>

    <!-- Navegación de meses -->
    <div class="flex justify-between items-center mb-4">
        <button id="prevMonth" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600">Mes Anterior</button>
        <h2 id="currentMonth" class="text-xl font-semibold"></h2>
        <button id="nextMonth" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600">Mes Siguiente</button>
    </div>

    <div class="overflow-x-auto">
        <table id="dashboardTable" class="min-w-full border-collapse border border-black text-sm text-center shadow-md rounded-lg">
            <thead class="bg-gray-200 text-black font-semibold">
                <tr>
                    <th class="border border-black px-4 py-2">Habitación</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-black">
            </tbody>
        </table>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", async () => {
        let currentDate = new Date();
        
        const updateCalendar = async () => {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth() + 1;
            const daysInMonth = new Date(year, month, 0).getDate();

            // Actualizar título del mes
            const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
            document.getElementById("currentMonth").textContent = `${monthNames[month - 1]} ${year}`;

            const table = document.getElementById("dashboardTable");
            const theadRow = table.querySelector("thead tr");
            const tbody = table.querySelector("tbody");

            // Limpiar encabezados y filas existentes
            theadRow.innerHTML = '<th class="border border-black px-4 py-2">Habitación</th>';
            tbody.innerHTML = '';

            // Encabezados de días
            for (let day = 1; day <= daysInMonth; day++) {
                const th = document.createElement("th");
                th.className = "border border-black px-2 py-2 text-xs";
                th.textContent = day;
                theadRow.appendChild(th);
            }

            // Cargar habitaciones y reservas
            const roomsRes = await fetch("/api/rooms");
            const reservationsRes = await fetch("/api/reservations");
            if (!roomsRes.ok || !reservationsRes.ok) return;

            const rooms = await roomsRes.json();
            const reservations = await reservationsRes.json();

            rooms.forEach(room => {
                const tr = document.createElement("tr");
                tr.className = "odd:bg-white even:bg-gray-50 text-black";

                const tdRoom = document.createElement("td");
                tdRoom.className = "border border-black px-4 py-2 font-semibold";
                tdRoom.textContent = room.number + " (" + room.type + ")";
                tr.appendChild(tdRoom);

                for (let day = 1; day <= daysInMonth; day++) {
                    const date = new Date(year, month - 1, day);
                    const td = document.createElement("td");
                    td.className = "border border-black px-1 py-1 relative";

                    // Obtener reservas para este día, incluyendo día de salida
                    const dayReservations = reservations.filter(r =>
                        r.roomId === room.id &&
                        new Date(r.entryDate) <= date &&
                        new Date(r.exitDate) >= date
                    );

                    if (dayReservations.length > 0) {
                        const container = document.createElement("div");
                        container.className = "h-full flex flex-col gap-1 min-h-[2rem]";

                        const entryReservations = dayReservations.filter(r => new Date(r.entryDate).toDateString() === date.toDateString());
                        const exitReservations = dayReservations.filter(r => new Date(r.exitDate).toDateString() === date.toDateString());
                        const betweenReservations = dayReservations.filter(r => {
                            const entry = new Date(r.entryDate);
                            const exit = new Date(r.exitDate);
                            return date > entry && date < exit;
                        });

                        const createClickArea = (td, side) => {
                            const clickArea = document.createElement("div");
                            clickArea.style.position = "absolute";
                            clickArea.style.top = "0";
                            clickArea.style.bottom = "0";
                            clickArea.style.width = "50%";
                            clickArea.style.cursor = "pointer";
                            clickArea.style[side] = "0";
                            clickArea.addEventListener("click", (e) => {
                                e.stopPropagation();
                                const newDate = new Date(year, month - 1, day);
                                document.getElementById("roomId").value = room.id;
                                document.getElementById("entryDate").value = newDate.toISOString().split('T')[0];
                                document.getElementById("exitDate").value = new Date(newDate.getTime() + 24 * 60 * 60 * 1000).toISOString().split('T')[0];
                                document.getElementById("reservationModal").classList.remove("hidden");
                            });
                            td.appendChild(clickArea);
                        };

                        if (betweenReservations.length > 0 || (entryReservations.length > 0 && exitReservations.length > 0)) {
                            const bar = document.createElement("div");
                            bar.className = "h-8 rounded-sm";
                            let color = "#22c55e";
                            if (betweenReservations.length > 0) {
                                const estado = betweenReservations[0].status || "ocupado";
                                if (estado === "mantenimiento") color = "#facc15";
                                else if (estado === "bloqueado") color = "#ef4444";
                                bar.style.background = color;
                            } else {
                                const exitColor = exitReservations.length > 0 ? (exitReservations[0].status === "mantenimiento" ? "#facc15" : exitReservations[0].status === "bloqueado" ? "#ef4444" : "#22c55e") : "#22c55e";
                                const entryColor = entryReservations.length > 0 ? (entryReservations[0].status === "mantenimiento" ? "#facc15" : entryReservations[0].status === "bloqueado" ? "#ef4444" : "#22c55e") : exitColor;
                                bar.style.background = `linear-gradient(to right, ${exitColor} 50%, ${entryColor} 50%)`;
                            }
                            container.appendChild(bar);
                        } else {
                            if (entryReservations.length > 0) {
                                entryReservations.forEach(res => {
                                    const color = res.status === "mantenimiento" ? "#facc15" : res.status === "bloqueado" ? "#ef4444" : "#22c55e";
                                    const wrapper = document.createElement("div");
                                    wrapper.className = "relative h-8 rounded-sm overflow-hidden";
                                    wrapper.style.background = "white";
                                    const bar = document.createElement("div");
                                    bar.className = "h-full";
                                    bar.style.background = `linear-gradient(to right, transparent 50%, ${color} 50%)`;
                                    wrapper.appendChild(bar);
                                    createClickArea(wrapper, "left");
                                    container.appendChild(wrapper);
                                });
                            }
                            if (exitReservations.length > 0) {
                                exitReservations.forEach(res => {
                                    const color = res.status === "mantenimiento" ? "#facc15" : res.status === "bloqueado" ? "#ef4444" : "#22c55e";
                                    const wrapper = document.createElement("div");
                                    wrapper.className = "relative h-8 rounded-sm overflow-hidden";
                                    wrapper.style.background = "white";
                                    const bar = document.createElement("div");
                                    bar.className = "h-full";
                                    bar.style.background = `linear-gradient(to right, ${color} 50%, transparent 50%)`;
                                    wrapper.appendChild(bar);
                                    if (entryReservations.length === 0) {
                                        createClickArea(wrapper, "right");
                                    }
                                    container.appendChild(wrapper);
                                });
                            }
                        }

                        td.appendChild(container);
                    } else {
                        td.style.background = "transparent";
                        td.style.cursor = "pointer";
                        td.addEventListener("click", () => {
                            const newDate = new Date(year, month - 1, day);
                            document.getElementById("roomId").value = room.id;
                            document.getElementById("entryDate").value = newDate.toISOString().split('T')[0];
                            document.getElementById("exitDate").value = new Date(newDate.getTime() + 24 * 60 * 60 * 1000).toISOString().split('T')[0];
                            document.getElementById("reservationModal").classList.remove("hidden");
                        });
                    }

                    tr.appendChild(td);
                }

                tbody.appendChild(tr);
            });
        };

        // Inicializar calendario
        await updateCalendar();

        // Eventos de navegación
        document.getElementById("prevMonth").addEventListener("click", async () => {
            currentDate.setMonth(currentDate.getMonth() - 1);
            await updateCalendar();
        });

        document.getElementById("nextMonth").addEventListener("click", async () => {
            currentDate.setMonth(currentDate.getMonth() + 1);
            await updateCalendar();
        });
    });

    function closeReservationModal() {
        document.getElementById("reservationModal").classList.add("hidden");
    }
</script>

@await Html.PartialAsync("_ReservationModal")
