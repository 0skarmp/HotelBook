@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="flex">
    @await Html.PartialAsync("_SideBar")

    <div class="flex-1 ml-64">
        @await Html.PartialAsync("_Header")

        <main class="p-6">
            <h1 class="text-2xl font-bold mb-4 text-red-800">Bienvenido al Dashboard</h1>

            <!-- Botón para abrir modal de creación -->
            <div class="mb-4">
                <button id="openCreateModalBtn" class="px-4 py-2 bg-blue-600 text-white rounded">
                    <i class="fa-solid fa-plus"></i> Add Room
                </button>
            </div>

            <!-- Contenedor de habitaciones -->
            <div id="roomsContainer" class="grid grid-cols-3 gap-4">
                <!-- Aquí se insertan las tarjetas -->
            </div>
        </main>
    </div>
</div>

<!-- Importar modal de creación -->
@await Html.PartialAsync("_CreateRoomModal")

<!-- Importar modal de reserva -->


<script>
    // 🔹 Cargar todas las habitaciones al iniciar
    async function loadRooms() {
        const response = await fetch("/api/rooms");
        if (response.ok) {
            const rooms = await response.json();
            const container = document.getElementById("roomsContainer");
            container.innerHTML = "";

            rooms.forEach(room => {
                const cardHtml = `
                    <div id="room-${room.id}"
                         class="p-4 rounded shadow-md text-gray-800 text-sm ${room.status === "Libre" ? "bg-green-200" : "bg-red-200"} cursor-pointer"
                         onclick="openReservationModal(${room.id})">
                        <div class="flex justify-between items-center">
                            <div>
                                <h2 class="font-bold text-lg">${room.number}</h2>
                                <p class="text-sm">${room.type}</p>
                            </div>
                            <span class="px-2 py-1 ${room.status === "Libre" ? "bg-green-600" : "bg-red-600"} text-white text-xs rounded">${room.status}</span>
                        </div>
                        <div class="flex flex-col items-center mt-4">
                            <i class="fa-solid ${room.status === "Libre" ? "fa-check-circle text-green-600" : "fa-times-circle text-red-600"} text-3xl"></i>
                            <p class="${room.status === "Libre" ? "text-green-600" : "text-red-600"} mt-2">${room.status === "Libre" ? "Disponible" : "Ocupada"}</p>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML("beforeend", cardHtml);
            });
        } else {
            alert("Error al cargar habitaciones");
        }
    }

    // 🔹 Abrir modal de creación
    document.getElementById("openCreateModalBtn").addEventListener("click", () => {
        document.getElementById("createRoomModal").classList.remove("hidden");
    });

    // 🔹 Cerrar modal de creación
    document.getElementById("closeCreateModalBtn").addEventListener("click", () => {
        document.getElementById("createRoomModal").classList.add("hidden");
    });

    // 🔹 Crear habitación en DB
    document.getElementById("createRoomForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const number = document.getElementById("roomNumber").value;
        const type = document.getElementById("roomType").value;

        const response = await fetch("/api/rooms", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ number, type })
        });

        if (response.ok) {
            await loadRooms(); // refrescar lista completa
            document.getElementById("createRoomModal").classList.add("hidden");
            document.getElementById("createRoomForm").reset();
        } else {
            alert("Error al guardar la habitación en la base de datos");
        }
    });

    // 🔹 Abrir modal de reserva
    function openReservationModal(roomId) {
        document.getElementById("reservationRoomId").value = roomId;
        document.getElementById("reservationModal").classList.remove("hidden");
    }

    // 🔹 Cargar habitaciones al iniciar
    document.addEventListener("DOMContentLoaded", loadRooms);
</script>
