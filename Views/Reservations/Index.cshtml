@{
    ViewData["Title"] = "Reservas";
    ViewData["ShowSidebar"] = true;
    Layout = "_Layout";
}

@await Html.PartialAsync("_Header")

<main class="p-6">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-blue-700">Lista de Reservas</h1>
        <p class="text-gray-600">Gestiona y consulta las reservas registradas en el hotel</p>
    </div>

    <section class="bg-white shadow rounded p-4 mb-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">Turno de Usuario</h2>
                <p class="text-sm text-gray-500">Datos del usuario que esta registrando reservas</p>
            </div>
            <a href="/Dashboard" class="inline-flex items-center justify-center px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                Agregar Reserva
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-4 text-sm">
            <div class="border border-gray-200 rounded p-3">
                <span class="block text-gray-500">Usuario</span>
                <strong id="shiftUserName" class="text-gray-900">Invitado</strong>
            </div>
            <div class="border border-gray-200 rounded p-3">
                <span class="block text-gray-500">Hora de ingreso</span>
                <strong id="shiftLoginAt" class="text-gray-900">N/A</strong>
            </div>
            <div class="border border-gray-200 rounded p-3">
                <span class="block text-gray-500">Hora de salida</span>
                <strong id="shiftLogoutAt" class="text-gray-900">Turno activo</strong>
            </div>
        </div>
    </section>

    <section class="bg-white shadow rounded p-4">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between mb-4">
            <div>
                <h2 id="reservationsTitle" class="text-xl font-semibold text-gray-900">Todas las Reservas</h2>
                <p id="reservationsSubtitle" class="text-sm text-gray-500">Busca por fecha de reserva o nombre del huesped</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 w-full xl:w-auto">
                <div>
                    <label for="searchName" class="block text-xs font-semibold text-gray-600 mb-1">Nombre</label>
                    <input id="searchName" type="search" placeholder="Nombre o apellido"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none" />
                </div>
                <div>
                    <label for="searchDate" class="block text-xs font-semibold text-gray-600 mb-1">Fecha</label>
                    <input id="searchDate" type="date"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none" />
                </div>
                <button id="showAllBtn" type="button"
                        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 self-end">
                    Todas las reservas
                </button>
                <button id="showShiftBtn" type="button"
                        class="px-4 py-2 bg-gray-700 text-white rounded hover:bg-gray-800 self-end">
                    Reservas de mi turno
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table id="reservationsTable" class="min-w-full border-collapse border border-gray-300 text-sm shadow-md rounded-lg">
                <thead class="bg-gray-100 text-gray-800 font-semibold">
                    <tr>
                        <th class="border border-gray-300 px-4 py-3 text-left">Reserva ID</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Habitacion</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Huesped</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Pais</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Registrada</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Entrada</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Salida</th>
                        <th class="border border-gray-300 px-4 py-3 text-left">Estado</th>
                    </tr>
                </thead>
                <tbody id="reservationsBody" class="divide-y divide-gray-200"></tbody>
            </table>
        </div>
    </section>
</main>

<script>
    document.addEventListener("DOMContentLoaded", async () => {
        const state = {
            mode: "all",
            reservations: [],
            reports: [],
            currentUser: JSON.parse(localStorage.getItem("hotelCurrentUser") || "null"),
            lastShift: JSON.parse(localStorage.getItem("hotelLastShift") || "null")
        };

        const activeShift = state.currentUser || state.lastShift;
        const reservationsBody = document.getElementById("reservationsBody");
        const reservationsTitle = document.getElementById("reservationsTitle");
        const reservationsSubtitle = document.getElementById("reservationsSubtitle");
        const searchName = document.getElementById("searchName");
        const searchDate = document.getElementById("searchDate");
        const showAllBtn = document.getElementById("showAllBtn");
        const showShiftBtn = document.getElementById("showShiftBtn");

        const formatDate = (value) => value ? new Date(value).toLocaleDateString("es-PE") : "N/A";
        const formatDateTime = (value) => value ? new Date(value).toLocaleString("es-PE") : "N/A";
        const dateKey = (value) => {
            if (!value) {
                return "";
            }

            const date = new Date(value);
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        };

        const setText = (id, value) => {
            document.getElementById(id).textContent = value;
        };

        if (activeShift && activeShift.username) {
            setText("shiftUserName", activeShift.username);
            const shiftLoginAt = activeShift.loginAt ? new Date(activeShift.loginAt) : null;
            const expectedLogoutAt = shiftLoginAt ? new Date(shiftLoginAt.getTime() + 8 * 60 * 60 * 1000) : null;

            setText("shiftLoginAt", shiftLoginAt ? formatDateTime(shiftLoginAt) : "N/A");
            setText("shiftLogoutAt", activeShift.logoutAt ? formatDateTime(activeShift.logoutAt) : formatDateTime(expectedLogoutAt));
        }

        const [reservationsRes, reportsRes] = await Promise.all([
            fetch("/api/reservations"),
            fetch("/api/reservations/reports/today")
        ]);

        if (reservationsRes.ok) {
            state.reservations = await reservationsRes.json();
        }

        if (reportsRes.ok) {
            state.reports = await reportsRes.json();
        }

        const getCreatedReport = (reservationId) => {
            return state.reports.find(report =>
                report.actionType === "Create" && Number(report.reservationId) === Number(reservationId)
            );
        };

        const getShiftReservationIds = () => {
            if (!activeShift || !activeShift.username) {
                return new Set();
            }

            const loginAt = activeShift.loginAt ? new Date(activeShift.loginAt) : new Date(0);
            const logoutAt = activeShift.logoutAt ? new Date(activeShift.logoutAt) : new Date();
            const userId = String(activeShift.id || "");
            const userName = String(activeShift.username || "").toLowerCase();

            return new Set(
                state.reports
                    .filter(report => {
                        const reportDate = new Date(report.date);
                        const reportUserId = String(report.userId || "");
                        const reportUserName = String(report.userName || "").toLowerCase();
                        const sameUser = (userId && reportUserId === userId) || reportUserName === userName;

                        return report.actionType === "Create"
                            && report.reservationId
                            && sameUser
                            && reportDate >= loginAt
                            && reportDate <= logoutAt;
                    })
                    .map(report => report.reservationId)
            );
        };

        const getFilteredReservations = () => {
            const nameTerm = searchName.value.trim().toLowerCase();
            const selectedDate = searchDate.value;
            let items = [...state.reservations];

            if (state.mode === "shift") {
                const shiftReservationIds = getShiftReservationIds();
                items = items.filter(reservation => shiftReservationIds.has(reservation.id));
            }

            if (nameTerm) {
                items = items.filter(reservation => {
                    const fullName = `${reservation.firstName || ""} ${reservation.middleName || ""} ${reservation.lastName || ""}`.toLowerCase();
                    return fullName.includes(nameTerm);
                });
            }

            if (selectedDate) {
                items = items.filter(reservation =>
                    dateKey(reservation.entryDate) === selectedDate
                    || dateKey(reservation.exitDate) === selectedDate
                    || dateKey(getCreatedReport(reservation.id)?.date) === selectedDate
                );
            }

            return items.sort((a, b) => new Date(b.entryDate) - new Date(a.entryDate));
        };

        const renderReservations = () => {
            const reservations = getFilteredReservations();
            reservationsBody.innerHTML = "";

            reservationsTitle.textContent = state.mode === "shift" ? "Reservas de mi turno" : "Todas las Reservas";
            reservationsSubtitle.textContent = state.mode === "shift"
                ? "Reservas generadas por el usuario del turno actual"
                : "Busca por fecha de entrada, fecha de salida o nombre del huesped";

            showAllBtn.className = state.mode === "all"
                ? "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 self-end"
                : "px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300 self-end";
            showShiftBtn.className = state.mode === "shift"
                ? "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 self-end"
                : "px-4 py-2 bg-gray-700 text-white rounded hover:bg-gray-800 self-end";

            if (!reservations.length) {
                const emptyRow = document.createElement("tr");
                emptyRow.innerHTML = `
                    <td colspan="8" class="border border-gray-300 px-4 py-6 text-center text-gray-500">
                        No se encontraron reservas con los filtros seleccionados.
                    </td>
                `;
                reservationsBody.appendChild(emptyRow);
                return;
            }

            reservations.forEach(reservation => {
                const exitDate = new Date(reservation.exitDate);
                const isActive = exitDate > new Date();
                const createdReport = getCreatedReport(reservation.id);
                const tr = document.createElement("tr");
                tr.className = "hover:bg-gray-50";
                tr.innerHTML = `
                    <td class="border border-gray-300 px-4 py-3 font-medium">#${reservation.id}</td>
                    <td class="border border-gray-300 px-4 py-3 font-medium">${reservation.room ? reservation.room.number + " (" + reservation.room.type + ")" : "N/A"}</td>
                    <td class="border border-gray-300 px-4 py-3">${reservation.firstName || ""} ${reservation.middleName || ""} ${reservation.lastName || ""}</td>
                    <td class="border border-gray-300 px-4 py-3">${reservation.country || "N/A"}</td>
                    <td class="border border-gray-300 px-4 py-3">${createdReport ? formatDateTime(createdReport.date) : "N/A"}</td>
                    <td class="border border-gray-300 px-4 py-3">${formatDate(reservation.entryDate)}</td>
                    <td class="border border-gray-300 px-4 py-3">${formatDate(reservation.exitDate)}</td>
                    <td class="border border-gray-300 px-4 py-3">
                        <span class="px-2 py-1 rounded-full text-xs font-medium ${isActive ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800"}">
                            ${isActive ? "Activa" : "Completada"}
                        </span>
                    </td>
                `;
                reservationsBody.appendChild(tr);
            });
        };

        showAllBtn.addEventListener("click", () => {
            state.mode = "all";
            renderReservations();
        });

        showShiftBtn.addEventListener("click", () => {
            state.mode = "shift";
            renderReservations();
        });

        searchName.addEventListener("input", renderReservations);
        searchDate.addEventListener("change", renderReservations);
        renderReservations();
    });
</script>
